# TurfOps Environment Variables
# Copy this file to .env and fill in your values.

# ─── App Database (managed by docker compose) ───
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=turfops
DATABASE_USER=turfops
DATABASE_PASSWORD=changeme
DB_PASSWORD=changeme

# ─── Server ───
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
# Optional: restrict CORS to a specific origin (default: http://localhost:3000)
# Set to * for permissive access during development
# CORS_ALLOWED_ORIGIN=http://localhost:5173

# ─── Lawn Profile Defaults ───
LAWN_NAME=Main Lawn
LAWN_GRASS_TYPE=TallFescue
LAWN_USDA_ZONE=7a
LAWN_SOIL_TYPE=Loam
LAWN_SIZE_SQFT=5000
LAWN_IRRIGATION_TYPE=InGround

# ─── NOAA Station ───
NOAA_STATION_WBANNO=3761

# ─── SoilData PostgreSQL (external NOAA database) ───
SOILDATA_DB_HOST=host.docker.internal
SOILDATA_DB_PORT=5432
SOILDATA_DB_NAME=uscrn
SOILDATA_DB_USER=postgres
SOILDATA_DB_PASSWORD=changeme

# ─── Home Assistant ───
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here
HA_TEMPERATURE_ENTITY=sensor.temp_humidity_sensor_temperature
HA_HUMIDITY_ENTITY=sensor.temp_humidity_sensor_humidity
HA_TEMPERATURE_UNIT=fahrenheit

# ─── OpenWeatherMap (optional) ───
OWM_API_KEY=your_api_key_here
OWM_LATITUDE=0.00
OWM_LONGITUDE=-0.00
OWM_ENABLED=true

# ─── Logging ───
RUST_LOG=info
