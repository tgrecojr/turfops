# TurfOps Backend Configuration
# Copy to .env and fill in your values

# App Database
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=turfops
DATABASE_USER=turfops
DATABASE_PASSWORD=your_password_here

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
# Optional: restrict CORS to a specific origin (default: http://localhost:3000)
# Set to * for permissive access during development
# CORS_ALLOWED_ORIGIN=http://localhost:5173

# Lawn Profile
LAWN_NAME=Main Lawn
LAWN_GRASS_TYPE=TallFescue
LAWN_USDA_ZONE=7a
LAWN_SOIL_TYPE=Loam
LAWN_SIZE_SQFT=5000
LAWN_IRRIGATION_TYPE=InGround

# NOAA Station (PA Avondale = 3761)
NOAA_STATION_WBANNO=3761

# SoilData PostgreSQL (external NOAA USCRN database)
SOILDATA_DB_HOST=localhost
SOILDATA_DB_PORT=5432
SOILDATA_DB_NAME=uscrn
SOILDATA_DB_USER=postgres
SOILDATA_DB_PASSWORD=

# Home Assistant (leave HA_TOKEN empty to disable)
HA_URL=http://localhost:8123
HA_TOKEN=
HA_TEMPERATURE_ENTITY=sensor.temp_humidity_sensor_temperature
HA_HUMIDITY_ENTITY=sensor.temp_humidity_sensor_humidity
HA_TEMPERATURE_UNIT=fahrenheit

# OpenWeatherMap (leave OWM_API_KEY empty to disable)
OWM_API_KEY=
OWM_LATITUDE=39.83
OWM_LONGITUDE=-75.87
OWM_ENABLED=true

# Logging
RUST_LOG=info
